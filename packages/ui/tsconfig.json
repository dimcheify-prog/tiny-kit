{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "types": ["node"],
    "outDir": "dist",
    "rootDir": ".",
    "module": "preserve",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
